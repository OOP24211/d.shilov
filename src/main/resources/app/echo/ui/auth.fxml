<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="app.echo.ui.AuthController"
           styleClass="auth-root">

    <VBox alignment="CENTER" spacing="18.0" maxWidth="340">
        <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>

        <StackPane styleClass="logo-circle" maxWidth="72" maxHeight="72" minWidth="72" minHeight="72">
            <Label text="E" styleClass="logo-letter"/>
        </StackPane>

        <Label text="Echo" styleClass="auth-title">
            <font><Font name="System Bold" size="30.0"/></font>
        </Label>
        <Label text="мгновенные сообщения" styleClass="auth-subtitle"/>

        <TextField fx:id="loginField" promptText="Логин" styleClass="input-pill"/>
        <PasswordField fx:id="passwordField" promptText="Пароль" styleClass="input-pill"/>

        <Button fx:id="loginBtn" text="Войти" onAction="#onLogin"
                styleClass="btn-accent" maxWidth="Infinity" prefHeight="42"/>
        <Button fx:id="registerBtn" text="Создать аккаунт" onAction="#onRegister"
                styleClass="btn-ghost" maxWidth="Infinity" prefHeight="42"/>

        <Label fx:id="statusLabel" wrapText="true" styleClass="auth-status"/>
    </VBox>
</StackPane>
